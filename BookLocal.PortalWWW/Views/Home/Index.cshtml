@{
    ViewData["Title"] = "Strona główna";
}
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
</head>
<style>
    .btn-primary-custom {
        background-color: #4F46E5;
        border-color: #4F46E5;
        color: white;
    }

        .btn-primary-custom:hover {
            background-color: white;
            border-color: #4338CA;
            color: #4338CA;
        }

    .btn-outline-primary-custom {
        border: 2px solid #4F46E5;
        color: #4F46E5;
        background-color: transparent;
    }

        .btn-outline-primary-custom:hover {
            background-color: #4F46E5;
            color: white;
        }

    .section-bg {
        background-color: #F9FAFB;
        padding: 60px 20px;
    }

    .text-secondary-custom {
        color: #6B7280;
    }
</style>


<div class="text-center mt-5">
    @await Html.PartialAsync("Naglowek",
            (IEnumerable<BookLocal.Data.Data.CMS.NaglowekCms>)ViewBag.ModelNaglowek)
    <div class="mt-4">
        <a asp-controller="Usluga" asp-action="Index" class="btn btn-primary-custom btn-lg me-2">Przeglądaj usługi</a>
        <a asp-controller="Rejestracja" asp-action="Index" class="btn btn-primary-custom btn-lg">Dołącz do nas</a>
    </div>
</div>


@await Html.PartialAsync("Sekcja",
                (IEnumerable<BookLocal.Data.Data.CMS.SekcjaCms>)ViewBag.ModelSekcja)

<div class="section-bg">
    <div class="container text-center">
        <h3 style="color: #4F46E5;">Zaufali nam</h3>
        <div id="logoCarousel" class="carousel slide mt-4" data-bs-ride="carousel">
            <div class="carousel-inner d-flex align-items-center">
                <div class="carousel-item active">
                    @for (int i = 1; i < 4; i++)
                    {
                        <img src="~/content/logo1.png" class="mx-3" style="max-height: 60px;" alt="Logo 1">
                        <img src="~/content/logo1.png" class="mx-3" style="max-height: 60px;" alt="Logo 2">
                        <img src="~/content/logo1.png" class="mx-3" style="max-height: 60px;" alt="Logo 3">
                    }
                </div>
                <div class="carousel-item">
                    @for (int i = 1; i < 4; i++)
                    {
                        <img src="~/content/logo2.png" class="mx-3" style="max-height: 60px;" alt="Logo 4">
                        <img src="~/content/logo2.png" class="mx-3" style="max-height: 60px;" alt="Logo 5">
                        <img src="~/content/logo2.png" class="mx-3" style="max-height: 60px;" alt="Logo 6">
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const carouselElement = document.querySelector('#logoCarousel');
    const carousel = new bootstrap.Carousel(carouselElement, {
        interval: 3000,
        ride: 'carousel',
        pause: false,
        wrap: true
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}