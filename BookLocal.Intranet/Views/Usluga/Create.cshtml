@model BookLocal.Data.Data.PlatformaInternetowa.Usluga

@{
    ViewData["Title"] = "Dodaj usługę";
}

<h1 class="text-primary mb-4 page-title"><i class="fas fa-plus-circle me-2"></i>@ViewData["Title"]</h1>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8"> 
        <div class="card shadow-sm mb-4 form-card">
            <div class="card-header form-card-header">
                 <i class="fas fa-info-circle me-2"></i> Wprowadź dane nowej usługi
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small p-2" role="alert"></div>
                    @Html.AntiForgeryToken()

                    <fieldset class="mb-4 form-section">
                        <legend class="form-section-legend">Podstawowe Informacje o Usłudze</legend>
                        <div class="mb-3">
                            <label asp-for="Nazwa" class="form-label"></label>
                            <input asp-for="Nazwa" class="form-control form-control-sm" placeholder="Pełna nazwa usługi" />
                            <span asp-validation-for="Nazwa" class="text-danger small"></span>
                        </div>
                       
                        <div class="mb-3">
                            <label asp-for="Opis" class="form-label"></label>
                            <textarea asp-for="Opis" class="form-control form-control-sm" rows="5" placeholder="Szczegółowy opis usługi widoczny dla klienta..."></textarea>
                            <span asp-validation-for="Opis" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ZdjecieUrl" class="form-label">Link URL do zdjęcia głównego</label>
                            <input asp-for="ZdjecieUrl" type="url" class="form-control form-control-sm" placeholder="https://... (link do obrazka online)" />
                            <span asp-validation-for="ZdjecieUrl" class="text-danger small"></span>
                             <div class="form-text small">Wklej publicznie dostępny URL do zdjęcia reprezentującego usługę.</div>
                        </div>
                    </fieldset>

                    <div class="form-actions">
                        <a asp-action="Index" class="btn btn-secondary btn-sm me-2">
                           <i class="fas fa-arrow-left me-1"></i> Anuluj
                        </a>
                        <button type="submit" value="Create" class="btn btn-success btn-sm">
                            <i class="fas fa-save me-1"></i> Utwórz Usługę
                        </button>
                    </div>
                </form>
            </div> 
        </div> 
    </div> 
</div> 

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}