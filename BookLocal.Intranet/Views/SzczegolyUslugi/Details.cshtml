@model BookLocal.Data.Data.PlatformaInternetowa.SzczegolyUslugi

@{
    ViewData["Title"] = "Szczegóły";
}

<h1 class="text-primary mb-4 page-title"><i class="fas fa-info-circle me-2"></i>@ViewData["Title"]</h1>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">
        <div class="card shadow-sm mb-4 display-card">
            <div class="card-header display-card-header">
                <i class="fas fa-tasks me-2"></i> Informacje o wariancie usługi
            </div>
            <div class="card-body px-4 py-4">
                <dl class="row details-list">
                    <dt class="col-sm-4 col-lg-3">Usługa Bazowa</dt>
                    <dd class="col-sm-8 col-lg-9">
                        <a asp-controller="Usluga" asp-action="Details" asp-route-id="@Model.UslugaId">
                            @Html.DisplayFor(model => model.Usluga.Nazwa)
                        </a>
                    </dd>

                    <dt class="col-sm-4 col-lg-3">Pracownik Wykonujący</dt>
                    <dd class="col-sm-8 col-lg-9">
                        <a asp-controller="Pracownik" asp-action="Details" asp-route-id="@Model.PracownikId">
                            @Html.DisplayFor(model => model.Pracownik.Imie) @Html.DisplayFor(model => model.Pracownik.Nazwisko)
                        </a>
                    </dd>

                    <dt class="col-sm-4 col-lg-3">@Html.DisplayNameFor(model => model.Opis)</dt>
                    <dd class="col-sm-8 col-lg-9">@Html.DisplayFor(model => model.Opis)</dd>

                    <dt class="col-sm-4 col-lg-3">@Html.DisplayNameFor(model => model.Cena)</dt>
                    <dd class="col-sm-8 col-lg-9 fw-bold">@Model.Cena.ToString("C", new System.Globalization.CultureInfo("pl-PL"))</dd>

                    <dt class="col-sm-4 col-lg-3">@Html.DisplayNameFor(model => model.CzasTrwaniaMinuty)</dt>
                    <dd class="col-sm-8 col-lg-9">@Model.CzasTrwaniaMinuty min</dd>

                </dl>
            </div>
            <div class="card-footer actions-footer">
                <a asp-action="Edit" asp-route-id="@Model?.IdSzczegolowUslugi" class="btn btn-warning btn-sm me-2">
                    <i class="fas fa-edit me-1"></i> Edytuj
                </a>
                <a asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i> Powrót do listy
                </a>
            </div>
        </div>
    </div>
</div> 