@model BookLocal.Data.Data.PlatformaInternetowa.SzczegolyUslugi

@{
    ViewData["Title"] = "Edytuj usługę";
}

<h1 class="text-primary mb-4 page-title"><i class="fas fa-edit me-2"></i>@ViewData["Title"]</h1>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">
        <div class="card shadow-sm mb-4 form-card">
            <div class="card-header form-card-header">
                <i class="fas fa-pencil-alt me-2"></i> Modyfikuj dane wariantu usługi
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small p-2" role="alert"></div>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="IdSzczegolowUslugi" />

                    <fieldset class="mb-4 form-section">
                        <legend class="form-section-legend">Przypisanie</legend>
                        <div class="row gx-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="UslugaId" class="form-label">Wybierz usługę</label>
                                <select asp-for="UslugaId" class="form-select form-select-sm" asp-items="ViewBag.UslugaId">
                                    <option value="">-- Wybierz usługę bazową --</option>
                                </select>
                                <span asp-validation-for="UslugaId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PracownikId" class="form-label">Wybierz pracownika</label>
                                <select asp-for="PracownikId" class="form-select form-select-sm" asp-items="ViewBag.PracownikId">
                                    <option value="">-- Wybierz pracownika --</option>
                                </select>
                                <span asp-validation-for="PracownikId" class="text-danger small"></span>
                            </div>
                        </div>
                    </fieldset>

                    <fieldset class="mb-4 form-section">
                        <legend class="form-section-legend">Szczegóły Wariantu</legend>
                        <div class="mb-3">
                            <label asp-for="Opis" class="form-label"></label>
                            <textarea asp-for="Opis" class="form-control form-control-sm" rows="3"></textarea>
                            <span asp-validation-for="Opis" class="text-danger small"></span>
                        </div>
                        <div class="row gx-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Cena" class="form-label"></label>
                                <div class="input-group input-group-sm">
                                    <input asp-for="Cena" type="number" step="0.01" min="0" class="form-control form-control-sm" />
                                    <span class="input-group-text">zł</span>
                                </div>
                                <span asp-validation-for="Cena" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="CzasTrwaniaMinuty" class="form-label"></label>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CzasTrwaniaMinuty" type="number" min="1" class="form-control form-control-sm" />
                                    <span class="input-group-text">min</span>
                                </div>
                                <span asp-validation-for="CzasTrwaniaMinuty" class="text-danger small"></span>
                            </div>
                        </div>
                    </fieldset>

                    <div class="form-actions">
                        <a asp-action="Index" class="btn btn-secondary btn-sm me-2">
                            <i class="fas fa-arrow-left me-1"></i> Anuluj
                        </a>
                        <button type="submit" value="Save" class="btn btn-success btn-sm">
                            <i class="fas fa-save me-1"></i> Zapisz zmiany
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}