@model BookLocal.Data.Data.PlatformaInternetowa.SzczegolyUslugi

@{
    ViewData["Title"] = "Usuń";
}

<h1 class="text-danger mb-4 page-title"><i class="fas fa-exclamation-triangle me-2"></i>@ViewData["Title"]</h1>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="card shadow-sm border-danger mb-4">
            <div class="card-header bg-danger text-white">
                <i class="fas fa-trash me-2"></i> Czy na pewno chcesz usunąć ten wariant usługi?
            </div>
            <div class="card-body">
                <p class="lead">Zamierzasz trwale usunąć wariant:</p>
                <h5 class="text-danger mb-3">@Model.Opis</h5>

                <p><strong>Podsumowanie danych do usunięcia:</strong></p>
                <dl class="row delete-summary small">
                    <dt class="col-sm-4">Usługa Bazowa</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Usluga.Nazwa)</dd>

                    <dt class="col-sm-4">Pracownik</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Pracownik.Imie) @Html.DisplayFor(model => model.Pracownik.Nazwisko)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Cena)</dt>
                    <dd class="col-sm-8">@Model.Cena.ToString("C", new System.Globalization.CultureInfo("pl-PL"))</dd>
                </dl>
                <hr>
                <p class="text-danger fw-bold"><i class="fas fa-exclamation-circle me-1"></i> Tej operacji nie można cofnąć!</p>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="IdSzczegolowUslugi" />

                    <div class="mt-4 delete-actions text-end">
                        <a asp-action="Index" class="btn btn-secondary btn-sm me-2">
                            <i class="fas fa-times me-1"></i> Anuluj
                        </a>
                        <button type="submit" value="Delete" class="btn btn-danger btn-sm">
                            <i class="fas fa-trash me-1"></i> Tak, usuń wariant
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div> 