@{
    ViewData["Title"] = "Opinie";
}

<style>
    .text-secondary {
        color: #6B7280; 
    }

    .text-indigo {
        color: #4F46E5; 
        font-weight: bold;
    }

    .card-body i {
        color: #4F46E5; 
    }

    .card {
        background-color: #F9FAFB; 
        border: 1px solid #E5E7EB;
        border-radius: 5px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: scale(1.02);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
    }

    .badge.bg-primary {
        background-color: #4F46E5;
    }

    .badge.bg-warning {
        background-color: #F59E0B;
    }

    .badge {
        font-size: 0.85rem;
        padding: 0.5rem;
    }

    .btn-secondary {
        background-color: #6B7280; 
        border: none;
        transition: background-color 0.3s ease;
    }

    .btn-secondary:hover {
        background-color: #525860;
    }


</style>

<h1 class="text-center mb-4" style="color: #4F46E5;">
    <i class="fas fa-star me-2" style="color: #4F46E5;"></i>Opinie
</h1>

<div class="container-fluid">
    <!-- Sekcja z podsumowaniem opinii -->
    <div class="row mb-4">
        <div class="col-md-4 text-center">
            <div class="card shadow-sm border-0 p-3">
                <h2 class="mb-1" style="color: #4F46E5;">4.5</h2>
                <p class="text-secondary">Średnia ocena</p>
                <i class="fas fa-star fa-3x" style="color: #4F46E5;"></i>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card shadow-sm border-0 p-3">
                <h2 class="mb-1" style="color: #4F46E5;">125</h2>
                <p class="text-secondary">Łączna liczba opinii</p>
                <i class="fas fa-users fa-3x" style="color: #4F46E5;"></i>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card shadow-sm border-0 p-3">
                <h2 class="mb-1" style="color: #4F46E5;">80%</h2>
                <p class="text-secondary">Pozytywne opinie</p>
                <i class="fas fa-smile fa-3x" style="color: #4F46E5;"></i>
            </div>
        </div>
    </div>

    <!-- Lista opinii -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h5 class="text-indigo mb-3">Pozytywne opinie</h5>
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h6 class="card-title"><i class="fas fa-user-circle me-2" style="color: #4F46E5;"></i>Anna Kowalska</h6>
                    <p class="text-secondary">"Świetna obsługa, pełen profesjonalizm!"</p>
                    <div class="text-end">
                        <span class="badge bg-primary"><i class="fas fa-star"></i> 5.0</span>
                    </div>
                    <button class="btn btn-secondary btn-sm mt-2"><i class="fas fa-reply"></i> Odpowiedz</button>
                </div>
            </div>
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h6 class="card-title"><i class="fas fa-user-circle me-2" style="color: #4F46E5;"></i>Piotr Nowak</h6>
                    <p class="text-secondary">"Zdecydowanie polecam, bardzo miła atmosfera."</p>
                    <div class="text-end">
                        <span class="badge bg-primary"><i class="fas fa-star"></i> 4.8</span>
                    </div>
                    <button class="btn btn-secondary btn-sm mt-2"><i class="fas fa-reply"></i> Odpowiedz</button>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <h5 class="text-indigo mb-3">Negatywne opinie</h5>
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h6 class="card-title"><i class="fas fa-user-circle me-2" style="color: #4F46E5;"></i>Janek Kowalski</h6>
                    <p class="text-secondary">"Obsługa mogłaby być bardziej pomocna."</p>
                    <div class="text-end">
                        <span class="badge bg-warning"><i class="fas fa-star"></i> 3.0</span>
                    </div>
                    <button class="btn btn-secondary btn-sm mt-2"><i class="fas fa-reply"></i> Odpowiedz</button>
                </div>
            </div>
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h6 class="card-title"><i class="fas fa-user-circle me-2" style="color: #4F46E5;"></i>Katarzyna Nowak</h6>
                    <p class="text-secondary">"Zbyt długi czas oczekiwania na rezerwację."</p>
                    <div class="text-end">
                        <span class="badge bg-warning"><i class="fas fa-star"></i> 2.8</span>
                    </div>
                    <button class="btn btn-secondary btn-sm mt-2"><i class="fas fa-reply"></i> Odpowiedz</button>
                </div>
            </div>
        </div>
    </div>
</div>
