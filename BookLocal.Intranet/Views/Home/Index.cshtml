@{
    ViewData["Title"] = "Panel Główny";
}

<style>
    /* Kolorystyka */
    .text-primary {
        color: #4F46E5; /* Indigo blue */
    }

    .text-secondary {
        color: #6B7280; /* Cool gray */
    }

    .text-indigo {
        color: #4F46E5; /* Indigo blue */
    }

    /* Karty w dashboardzie */
    .card {
        background-color: #F9FAFB; /* Light gray */
        border: 1px solid #E5E7EB; /* Jasny szary */
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card:hover {
        transform: scale(1.02); /* Subtelny efekt powiększenia */
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15); /* Dodanie cienia */
    }

    .card-title {
        font-weight: bold;
    }

    .btn-primary {
        background-color: #4F46E5; /* Indigo blue */
        border: none;
        transition: background-color 0.3s ease;
    }

    .btn-primary:hover {
        background-color: #3B3AB5; /* Ciemniejszy odcień niebieskiego */
    }

</style>

<div class="container-fluid mt-4">
    <h1 class="display-4 fw-bold" style="color: #4F46E5;"><i class="fas fa-tachometer-alt me-2"></i>Panel Główny</h1>

    <div class="row">
        <!-- Sekcja Specjaliści -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-indigo">Specjaliści</h5>
                    <p class="card-text text-secondary">Liczba specjalistów: <strong>25</strong></p>
                    <a asp-controller="Home" asp-action="Specjalisci" class="btn btn-primary btn-sm">Zobacz więcej</a>
                </div>
            </div>
        </div>

        <!-- Sekcja Usługi -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-indigo">Usługi</h5>
                    <p class="card-text text-secondary">Liczba dostępnych usług: <strong>50</strong></p>
                    <a asp-controller="Home" asp-action="Uslugi" class="btn btn-primary btn-sm">Zarządzaj usługami</a>
                </div>
            </div>
        </div>

        <!-- Sekcja Rezerwacje -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-indigo">Rezerwacje</h5>
                    <p class="card-text text-secondary">Oczekujące rezerwacje: <strong>8</strong></p>
                    <a asp-controller="Home" asp-action="Kategorie" class="btn btn-primary btn-sm">Przeglądaj rezerwacje</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Sekcja Klienci -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-indigo">Klienci</h5>
                    <p class="card-text text-secondary">Zarejestrowanych klientów: <strong>120</strong></p>
                    <a asp-controller="Home" asp-action="Klienci" class="btn btn-primary btn-sm">Zarządzaj klientami</a>
                </div>
            </div>
        </div>

        <!-- Sekcja Opinie -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-indigo">Opinie</h5>
                    <p class="card-text text-secondary">Nowe opinie: <strong>3</strong></p>
                    <a asp-controller="Home" asp-action="Opinie" class="btn btn-primary btn-sm">Sprawdź opinie</a>
                </div>
            </div>
        </div>

        <!-- Sekcja Lokalizacje -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-indigo">Lokalizacje</h5>
                    <p class="card-text text-secondary">Dodane lokalizacje: <strong>10</strong></p>
                    <a asp-controller="Home" asp-action="Lokalizacje" class="btn btn-primary btn-sm">Zarządzaj lokalizacjami</a>
                </div>
            </div>
        </div>
    </div>
</div>
